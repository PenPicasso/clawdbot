[Unit]
Description=OpenClaw — Telegram AI Agent Backend
Documentation=https://github.com/ShehuRingim/clawdbot
After=network-online.target ollama.service
Wants=network-online.target
Requires=ollama.service

[Service]
Type=exec
User=openclaw
Group=openclaw
WorkingDirectory=/opt/openclaw/app

# Load secrets from .env file
EnvironmentFile=/opt/openclaw/app/.env

# Start uvicorn — poller and scheduler run inside this process
ExecStart=/opt/openclaw/venv/bin/uvicorn openclaw.main:app \
    --host 0.0.0.0 \
    --port 8080 \
    --workers 1 \
    --loop uvloop \
    --no-access-log

# Restart on any non-zero exit
Restart=always
RestartSec=10

# Logs go to files (rotated by logrotate)
StandardOutput=append:/opt/openclaw/logs/openclaw.log
StandardError=append:/opt/openclaw/logs/openclaw-error.log

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/openclaw/data /opt/openclaw/logs

[Install]
WantedBy=multi-user.target
