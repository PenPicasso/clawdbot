# =============================================================================
# OpenClaw / ClawDBot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================

# --- Telegram ---
# Get this from @BotFather after creating your bot (/newbot)
TELEGRAM_BOT_TOKEN=

# Random 32-character string for webhook URL security.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=

# Your public HTTPS URL (no trailing slash).
# Options:
#   A) DuckDNS: https://yourname.duckdns.org
#   B) Cloudflare Tunnel URL (given to you by cloudflared)
WEBHOOK_BASE_URL=

# Your personal Telegram user ID (get it from @userinfobot)
ADMIN_CHAT_ID=

# --- Fast model (Ollama, runs locally on Oracle VM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- Deep model (Hugging Face Space) ---
# Your HF Space URL (no trailing slash)
# Example: https://shehuringim-clawdbot-27b.hf.space
HF_SPACE_URL=

# Secret token you set in HF Space Settings → Variables → OPENCLAW_SECRET
# Must match what you put in the HF Space environment.
HF_SPACE_SECRET=

# (Optional) HF read token for Inference API fallback.
# Create at huggingface.co/settings/tokens (read-only is fine)
HF_API_TOKEN=

# HF model for Inference API fallback (leave as default unless you changed it)
HF_API_MODEL=google/gemma-3-27b-it

# --- Storage ---
# Full path to SQLite database file on the Oracle VM
SQLITE_DB_PATH=/opt/openclaw/data/jobs.db

# --- Poller settings ---
POLL_INTERVAL_SECONDS=30
KEEPALIVE_INTERVAL_SECONDS=240
MAX_RETRIES=3
HF_INFER_TIMEOUT=300
FAST_INFER_TIMEOUT=15

# --- Scheduler ---
# Hour (0-23) for daily morning briefing
BRIEFING_HOUR=8
BRIEFING_MINUTE=0
# Your timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC
